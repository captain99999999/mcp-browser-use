# =============================================================================
# mcp-browser-use — 环境变量参考
# =============================================================================
# 复制为 .env 并填入你的值。
# 以 # 开头的行是注释，会被忽略。
#
# 所有 MCP_* 变量通过 Pydantic Settings（config.py）读取。
# API 密钥使用行业标准变量名（OPENAI_API_KEY 等），详见下方。
# =============================================================================


# =============================================================================
# LLM 配置（前缀: MCP_LLM_）
# =============================================================================

# 提供商选择（必填）
# 本项目使用 DeepSeek。可选值: openai, anthropic, google, azure_openai, groq,
# deepseek, cerebras, ollama, bedrock, browser_use, openrouter, vercel
# LLM provider. This fork uses DeepSeek by default.
MCP_LLM_PROVIDER=deepseek

# 模型名称（各提供商不同）
# 本项目使用 deepseek-v4-flash（快速模型，适合浏览器自动化）。
# 备选: deepseek-v4-pro（推理增强）、gpt-4o、claude-sonnet-4-20250514、gemini-3-flash-preview
# 注意: 旧名称 deepseek-chat / deepseek-reasoner 将于 2026-07-24 停用，请迁移到 V4 系列。
# Model name. This fork uses deepseek-v4-flash (fast model for browser automation).
# Alternatives: deepseek-v4-pro, gpt-4o, claude-sonnet-4-20250514, gemini-3-flash-preview
# Note: legacy names deepseek-chat/deepseek-reasoner will be EOL on 2026-07-24.
MCP_LLM_MODEL_NAME=deepseek-v4-flash

# 自定义 OpenAI 兼容 API 的基础 URL（vLLM、本地服务器等）
# Custom base URL for OpenAI-compatible APIs (vLLM, local servers, etc.)
# MCP_LLM_BASE_URL=http://localhost:8000/v1


# =============================================================================
# API 密钥 — 标准环境变量名（推荐）
# =============================================================================
# 服务端会根据 MCP_LLM_PROVIDER 自动检测对应变量。
# 优先级（从高到低）：
#   1. MCP_LLM_API_KEY          （通用覆盖，适用于任何提供商）
#   2. <PROVIDER>_API_KEY       （下方列出的标准变量名）
#   3. MCP_LLM_<PROVIDER>_API_KEY （MCP 前缀旧版，向后兼容）
#
# ollama 和 bedrock 不需要 API 密钥。

# OpenAI 的 API 密钥
# API key for OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic 的 API 密钥
# API key for Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Google / Gemini 的 API 密钥（GEMINI_API_KEY 优先于 GOOGLE_API_KEY）
# API key for Google / Gemini (GEMINI_API_KEY takes priority over GOOGLE_API_KEY)
# GEMINI_API_KEY=...

# Azure OpenAI 的 API 密钥（除密钥外还需要终端节点 + API 版本）
# API key for Azure OpenAI (requires endpoint + API version in addition to key)
# AZURE_OPENAI_API_KEY=...

# Groq 的 API 密钥
# API key for Groq
# GROQ_API_KEY=gsk_...

# DeepSeek 的 API 密钥
# API key for DeepSeek
# DEEPSEEK_API_KEY=sk-...

# Cerebras 的 API 密钥
# API key for Cerebras
# CEREBRAS_API_KEY=...

# Browser Use Cloud 的 API 密钥
# API key for Browser Use Cloud
# BROWSER_USE_API_KEY=...

# OpenRouter 的 API 密钥
# API key for OpenRouter
# OPENROUTER_API_KEY=sk-or-...

# Vercel AI Gateway 的 API 密钥
# API key for Vercel AI Gateway
# VERCEL_API_KEY=...


# =============================================================================
# 提供商专属配置
# =============================================================================

# --- Azure OpenAI ---
# Azure OpenAI 终端节点 URL
# Azure OpenAI endpoint URL
# MCP_LLM_AZURE_ENDPOINT=https://your-resource.openai.azure.com
# Azure OpenAI API 版本
# Azure OpenAI API version
# MCP_LLM_AZURE_API_VERSION=2024-02-01

# --- AWS Bedrock ---
# 使用标准 AWS 凭证（AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY）
# Uses standard AWS credentials (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY)
# AWS 区域
# AWS region
# MCP_LLM_AWS_REGION=us-east-1

# --- Ollama（本地部署） ---
# Ollama 服务地址
# Ollama server URL
# MCP_LLM_BASE_URL=http://localhost:11434


# =============================================================================
# 旧版 API 密钥变量名（MCP 前缀，优先级最低）
# =============================================================================
# 仅在 MCP_LLM_API_KEY 和标准变量名都未设置时使用。
# Only used if neither MCP_LLM_API_KEY nor the standard name is set.
# MCP_LLM_OPENAI_API_KEY=...
# MCP_LLM_ANTHROPIC_API_KEY=...
# MCP_LLM_GOOGLE_API_KEY=...


# =============================================================================
# 通用 API 密钥覆盖（最高优先级）
# =============================================================================
# 适用于任何提供商，方便快速测试。
# Applies to ANY provider. Useful for quick testing.
# MCP_LLM_API_KEY=...


# =============================================================================
# 浏览器配置（前缀: MCP_BROWSER_）
# =============================================================================

# 无头模式运行浏览器（无 GUI 窗口）
# 注意：使用 CDP 连接外部浏览器时此设置无效，浏览器模式由外部 Chrome 决定。
# 本项目的 browser-pool 运行的是有头 Chrome（9222/9226），故此变量不生效。
# Run browser in headless mode (no GUI window).
# Note: ignored when using CDP (external browser mode controls the actual Chrome).
# This project uses browser-pool with headed Chrome on 9222/9226, so this is not relevant.
# MCP_BROWSER_HEADLESS=true

# Chrome DevTools Protocol 远程调试地址（外部浏览器连接用）
# 本项目生产环境: 9222（默认）+ 9226（浏览器池第二实例）
# CDP URL for external browser. Production: 9222 (default) + 9226 (pool instance #2)
# MCP_BROWSER_CDP_URL=http://127.0.0.1:9222

# 浏览器池 — 多个 CDP URL 用于并发浏览器任务
# 设置后会覆盖 MCP_BROWSER_CDP_URL。JSON 数组格式，逗号分隔。
# 本项目实际使用 9222（主实例，有头）+ 9226（池实例，有头）
# Browser pool — multiple CDP URLs for concurrent browser tasks.
# Production uses 9222 (headed primary) + 9226 (headed pool instance).
# MCP_BROWSER_CDP_URLS=["http://127.0.0.1:9222","http://127.0.0.1:9226"]

# Chrome 用户数据目录（持久化配置文件、Cookie、登录状态）
# Chrome user data directory (persistent profile, cookies, logins)
# MCP_BROWSER_USER_DATA_DIR=C:\ChromeProfile

# 启用 Chromium 沙箱（建议开启以保证安全）
# 注意：使用 CDP 连接外部浏览器时此设置无效，沙箱由外部 Chrome 启动参数控制。
# Enable Chromium sandbox (recommended for security).
# Note: ignored when using CDP (sandbox is controlled by external Chrome's launch args).
# MCP_BROWSER_CHROMIUM_SANDBOX=true

# 浏览器流量的代理服务器地址
# Proxy server for browser traffic
# MCP_BROWSER_PROXY_SERVER=http://proxy:8080

# 不走代理的主机列表，逗号分隔
# Comma-separated hosts to bypass proxy
# MCP_BROWSER_PROXY_BYPASS=localhost,127.0.0.1,.internal


# =============================================================================
# Agent 配置（前缀: MCP_AGENT_）
# =============================================================================

# 每个浏览器任务的最大执行步数
# Maximum steps per browser task
MCP_AGENT_MAX_STEPS=20

# 启用视觉能力（LLM agent 可以通过截图感知页面内容）
# Enable vision capabilities (screenshots for the LLM agent)
MCP_AGENT_USE_VISION=true


# =============================================================================
# 服务器配置（前缀: MCP_SERVER_）
# =============================================================================

# 日志级别: DEBUG, INFO, WARNING, ERROR
# Log level: DEBUG, INFO, WARNING, ERROR
MCP_SERVER_LOGGING_LEVEL=INFO

# MCP 传输协议: stdio, streamable-http, sse
# MCP transport protocol: stdio, streamable-http, or sse
MCP_SERVER_TRANSPORT=stdio

# HTTP 监听地址（仅 streamable-http / sse 传输协议有效）
# HTTP host (only for streamable-http / sse transports)
MCP_SERVER_HOST=127.0.0.1

# HTTP 监听端口（仅 streamable-http / sse 传输协议有效）
# HTTP port (only for streamable-http / sse transports)
MCP_SERVER_PORT=8383

# 任务执行结果保存目录
# Directory to save task execution results
# MCP_SERVER_RESULTS_DIR=./results

# 非本机 HTTP 访问所需的 Bearer 认证令牌
# Bearer token for non-localhost HTTP access
# MCP_SERVER_AUTH_TOKEN=your-secret-token

# 最大并发浏览器任务数
# Maximum concurrent browser tasks
MCP_SERVER_MAX_CONCURRENT_TASKS=10

# 最大排队等待任务数
# Maximum queued tasks
MCP_SERVER_MAX_QUEUED_TASKS=100

# 告警阈值：正在运行的任务数超过此值时触发告警
# Alert threshold: trigger alert if running tasks exceed this number
MCP_SERVER_ALERT_MAX_RUNNING_TASKS=5

# 告警阈值：任务失败率超过此值（0-1）时触发告警
# Alert threshold: trigger alert if failure rate exceeds this value (0-1)
MCP_SERVER_ALERT_FAILURE_RATE=0.5


# =============================================================================
# 深度研究配置（前缀: MCP_RESEARCH_）
# =============================================================================

# 每个深度研究任务的最大搜索次数
# Maximum searches per deep research task
MCP_RESEARCH_MAX_SEARCHES=5

# 研究报告保存目录
# Directory to save research reports
# MCP_RESEARCH_SAVE_DIRECTORY=./tmp/research

# 单次搜索的超时时间（秒）
# Timeout per individual search (seconds)
MCP_RESEARCH_SEARCH_TIMEOUT=120


# =============================================================================
# 工具配置（前缀: MCP_TOOLS_）
# =============================================================================

# web_fetch 工具的超时时间（秒）
# Timeout for web_fetch tool (seconds)
MCP_TOOLS_WEB_FETCH_TIMEOUT=60

# web_search 工具的超时时间（秒）
# Timeout for web_search tool (seconds)
MCP_TOOLS_WEB_SEARCH_TIMEOUT=120

# DuckDuckGo API 后备搜索的超时时间（秒）
# Timeout for DuckDuckGo API fallback search (seconds)
MCP_TOOLS_SEARCH_TIMEOUT=30


# =============================================================================
# Skills 配置（前缀: MCP_SKILLS_）
# =============================================================================

# 启用机器学习浏览器技能（测试版）
# Enable machine-learned browser skills (beta)
MCP_SKILLS_ENABLED=false

# Skills 存储目录
# Skills storage directory
# MCP_SKILLS_DIRECTORY=~/.config/browser-skills

# 校验技能执行结果
# Validate skill execution results
MCP_SKILLS_VALIDATE_RESULTS=true


# =============================================================================
# 搜索代理（web_search 中 DuckDuckGo API 回退时使用）
# =============================================================================
# 优先级: MCP_PROXY > HTTPS_PROXY > HTTP_PROXY
# Priority: MCP_PROXY > HTTPS_PROXY > HTTP_PROXY
# MCP_PROXY=http://proxy:8080
# HTTPS_PROXY=http://proxy:8080
# HTTP_PROXY=http://proxy:8080


# =============================================================================
# 第三方库日志级别
# =============================================================================
# 抑制 browser-use 库的冗余日志（默认 "warning"）
# Suppresses verbose logs from the browser-use library (default "warning")
# BROWSER_USE_LOGGING_LEVEL=warning


# =============================================================================
# .env 文件路径（高级用法）
# =============================================================================
# 显式指定 .env 文件路径。未设置时 Pydantic 自动发现。
# Explicit path to .env file. If not set, Pydantic auto-discovers.
# MCP_BROWSER_USE_ENV_FILE=/path/to/.env
